@model List<Projeweb.Models.Tbl_SSS>
@{
    ViewBag.Title = "Sıkça Sorulan Sorular";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 600px;">
            <h6 class="text-primary text-uppercase">// Bilgi Merkezi //</h6>
            <h1 class="mb-4">Merak Edilen Her Şey</h1>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="accordion" id="accordionTumSayfa">
                    @foreach (var item in Model)
                    {
                        <div class="accordion-item mb-3 border-0 shadow-sm">
                            <h2 class="accordion-header" id="h-@item.ID">
                                <button class="accordion-button collapsed" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#t-soru-@item.ID">
                                    <i class="fa fa-question-circle text-primary me-3"></i> @item.Soru
                                </button>
                            </h2>
                            <div id="t-soru-@item.ID" class="accordion-collapse collapse"
                                 data-bs-parent="#accordionTumSayfa">
                                <div class="accordion-body bg-light">
                                    @item.Cevap
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>