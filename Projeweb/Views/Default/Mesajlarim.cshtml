@model List<Projeweb.Models.Tbl_Mesajlar>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-xxl py-5">
    <div class="container">
        <h1 class="text-center mb-5">Mesajlarım ve Yanıtlar</h1>
        <div class="table-responsive">
            <table class="table table-hover border shadow-sm">
                <thead class="bg-primary text-white">
                    <tr>
                        <th>Tarih</th>
                        <th>Konu</th>
                        <th>Durum</th>
                        <th>Detay / Yanıt</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Tarih.Value.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@item.Konu</td>
                            <td>
                                @if (string.IsNullOrEmpty(item.Cevap))
                                {
                                    <span class="badge bg-warning text-dark">Yanıt Bekleniyor</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Cevaplandı</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-info" data-bs-toggle="collapse" data-bs-target="#cevap-@item.MesajID">
                                    Mesajı ve Yanıtı Aç
                                </button>
                            </td>
                        </tr>
                        @* Tıklayınca açılan mesaj detayı ve admin yanıtı *@
                        <tr id="cevap-@item.MesajID" class="collapse bg-light">
                            <td colspan="4">
                                <div class="p-3">
                                    <p><b>Mesajınız:</b> @item.Mesaj</p>
                                    @if (!string.IsNullOrEmpty(item.Cevap))
                                    {
                                        <div class="mt-3 p-3 bg-white border-start border-4 border-success">
                                            <p class="mb-1 text-success"><b>Admin Yanıtı (@item.CevapTarihi.Value.ToString("g")):</b></p>
                                            <p class="mb-0">@item.Cevap</p>
                                        </div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>