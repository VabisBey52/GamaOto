@model List<Projeweb.Models.Tbl_Duyurular>

@{
    ViewBag.Title = "Tüm Duyurular";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/tema/img/gama.jpg); background-size: cover;">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center">
            <h1 class="display-3 text-white mb-3 animated slideInDown">Duyurular</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="/Default/AnaSayfa">Anasayfa</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Tüm Duyurular</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
            <h6 class="text-primary text-uppercase">// Güncel Haberler //</h6>
            <h1 class="mb-5">Tüm Duyuru ve Haberlerimiz</h1>
        </div>
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                    <div class="service-item bg-light rounded h-100 p-0 shadow-sm overflow-hidden">
                        <div class="position-relative">
                            <img class="img-fluid w-100" src="@item.ResimYolu" alt="@item.Baslik" style="height: 200px; object-fit: cover;">
                            <div class="bg-primary text-white position-absolute top-0 start-0 m-3 py-1 px-3 rounded-pill">
                                <small>@item.Tarih.Value.ToString("dd MMM yyyy")</small>
                            </div>
                        </div>
                        <div class="p-4">
                            <h5 class="mb-3 text-truncate">@item.Baslik</h5>
                            <p class="text-muted small mb-3">
                                <i class="fa fa-eye text-primary me-2"></i>@item.Goruntulenme İzlenme
                                <i class="fa fa-heart text-danger ms-3 me-2"></i>@item.BegeniSayisi Beğeni
                            </p>
                            <p class="mb-4">
                                @if (!string.IsNullOrEmpty(item.DuyuruMetni))
                                {
                                    @(item.DuyuruMetni.Length > 120 ? item.DuyuruMetni.Substring(0, 110) + "..." : item.DuyuruMetni)
                                }
                                else
                                {
                                    <span>İçerik henüz eklenmemiş.</span>
                                }
                            </p>
                            <a class="btn btn-sm btn-outline-primary rounded-pill py-2 px-4" href="/Default/DuyuruDetay/@item.DuyuruID">
                                Devamını Oku <i class="fa fa-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (Model.Count == 0)
            {
                <div class="col-12 text-center py-5">
                    <div class="alert alert-info">Şu an yayınlanmış bir duyuru bulunmuyor.</div>
                </div>
            }
        </div>
    </div>
</div>