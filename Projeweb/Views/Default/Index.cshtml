    <div class="container-fluid page-header mb-5 p-0" style="background-image: url(../tema/img/gama.jpg);">
        <div class="container-fluid page-header-inner py-5">
            <div class="container text-center">
                <h1 class="display-3 text-white mb-3 animated slideInDown">Teknisyenler</h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb justify-content-center text-uppercase">
                        <li class="breadcrumb-item"><a href="#">AnaSayfa</a></li>
                        <li class="breadcrumb-item"><a href="#">Sayfalar</a></li>
                        <li class="breadcrumb-item text-white active" aria-current="page">Teknisyenler</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>

    <div class="container-xxl py-5">
        <div class="container">
            <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
                <h6 class="text-primary text-uppercase">// Teknisyenlerimiz //</h6>
                <h1 class="mb-5">Uzman Teknisyenlerimiz</h1>
            </div>

            <div class="row g-4">
                @{
                    int tSayac = 0;
                    int toplamTeknisyen = Model.Teknisyenler.Count();
                }

                @foreach (var x in Model.Teknisyenler)
                {
                    tSayac++;

                    if (tSayac == 5)
                    {
                    @:</div><div class="row g-4 collapse mt-4" id="extraTeam">
                    }

                    <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="team-item shadow-sm border rounded">
                            <div class="position-relative overflow-hidden">
                                <img class="img-fluid w-100" src="@x.ResimYolu" style="height:300px; object-fit:cover;" alt="@x.AdSoyad">
                                <div class="team-overlay position-absolute start-0 top-0 w-100 h-100 d-flex align-items-center justify-content-center">
                                    <a class="btn btn-square mx-1" href=""><i class="fab fa-facebook-f"></i></a>
                                    <a class="btn btn-square mx-1" href=""><i class="fab fa-twitter"></i></a>
                                    <a class="btn btn-square mx-1" href=""><i class="fab fa-instagram"></i></a>
                                </div>
                            </div>
                            <div class="bg-light text-center p-4">
                                <h5 class="fw-bold mb-0">@x.AdSoyad</h5>
                                <small>@x.Gorev</small>
                            </div>
                        </div>
                    </div>
                }

                @if (tSayac >= 4)
                {
                @:</div>
            }
            </div>

            @if (toplamTeknisyen > 4)
            {
                <div class="text-center mt-5">
                    <button class="btn btn-primary py-3 px-5 rounded-pill shadow" type="button"
                            data-bs-toggle="collapse" data-bs-target="#extraTeam"
                            id="btnTeamToggle" onclick="teamBtnDegistir()">
                        Tüm Teknisyenlerimizi Gör <i class="fa fa-plus ms-2"></i>
                    </button>
                </div>
            }
        </div>


        <div class="container-xxl py-5">
            <div class="container">
                <div class="row g-5">
                    <div class="col-lg-6 pt-4" style="min-height: 400px;">
                        <div class="position-relative h-100 wow fadeIn" data-wow-delay="0.1s">
                            <img class="position-absolute img-fluid w-100 h-100" src="~/tema/img/about.jpg" style="object-fit: cover;" alt="">
                            <div class="position-absolute top-0 end-0 mt-n4 me-n4 py-4 px-5" style="background: rgba(0, 0, 0, .08);">
                                <h1 class="display-4 text-white mb-0">15 <span class="fs-4">Yıllık</span></h1>
                                <h4 class="text-white">Deneyim</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <h6 id="Hakkimda" class="text-primary text-uppercase">// Hakkımızda //</h6>
                        <h1 class="mb-4"><span class="text-primary">OtoServis</span> Aracınız İçin En İyi Adres</h1>
                        <p class="mb-4">Yılların verdiği tecrübe ile aracınızın tüm ihtiyaçlarını profesyonel bir şekilde karşılıyoruz. Güven ve kalite ilkemizdir.</p>
                        <div class="row g-4 mb-3 pb-3">
                            <div class="col-12 wow fadeIn" data-wow-delay="0.1s">
                                <div class="d-flex">
                                    <div class="bg-light d-flex flex-shrink-0 align-items-center justify-content-center mt-1" style="width: 45px; height: 45px;">
                                        <span class="fw-bold text-secondary">01</span>
                                    </div>
                                    <div class="ps-3">
                                        <h6>Profesyonel ve Uzman</h6>
                                        <span>Hizmet kalitemizi her geçen gün artırıyoruz.</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 wow fadeIn" data-wow-delay="0.3s">
                                <div class="d-flex">
                                    <div class="bg-light d-flex flex-shrink-0 align-items-center justify-content-center mt-1" style="width: 45px; height: 45px;">
                                        <span class="fw-bold text-secondary">02</span>
                                    </div>
                                    <div class="ps-3">
                                        <h6>Kaliteli Servis Merkezi</h6>
                                        <span>Orijinal parça ve garantili işçilik sunuyoruz.</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 wow fadeIn" data-wow-delay="0.5s">
                                <div class="d-flex">
                                    <div class="bg-light d-flex flex-shrink-0 align-items-center justify-content-center mt-1" style="width: 45px; height: 45px;">
                                        <span class="fw-bold text-secondary">03</span>
                                    </div>
                                    <div class="ps-3">
                                        <h6>Ödüllü Çalışanlar</h6>
                                        <span>Sektörün en iyi teknisyenleri ile çalışıyoruz.</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        @*<a href="" class="btn btn-primary py-3 px-5">Daha Fazla Bilgi<i class="fa fa-arrow-right ms-3"></i></a>*@
                    </div>
                </div>
            </div>
        </div>

        <div class="container-fluid page-header mb-5 p-0" style="background-image: url(../tema/img/gama.jpg); background-size: cover;">
            <div class="container-fluid page-header-inner py-5">
                <div class="container text-center">
                    <div class="row g-4">
                        <div class="col-md-6 col-lg-3 text-center wow fadeIn" data-wow-delay="0.1s">
                            <i class="fa fa-check fa-2x text-white mb-3"></i>
                            <h2 class="text-white mb-2" data-toggle="counter-up">15</h2>
                            <p class="text-white mb-0">Yıllık Deneyim</p>
                        </div>
                        <div class="col-md-6 col-lg-3 text-center wow fadeIn" data-wow-delay="0.3s">
                            <i class="fa fa-users-cog fa-2x text-white mb-3"></i>
                            <h2 class="text-white mb-2" data-toggle="counter-up">@ViewBag.TeknisyenSayisi</h2>
                            <p class="text-white mb-0">Uzman Teknisyen</p>
                        </div>
                        <div class="col-md-6 col-lg-3 text-center wow fadeIn" data-wow-delay="0.5s">
                            <i class="fa fa-users fa-2x text-white mb-3"></i>
                            <h2 class="text-white mb-2" data-toggle="counter-up">@ViewBag.Uyesayisi</h2>
                            <p class="text-white mb-0">Memnun Müşteri</p>
                        </div>
                        <div class="col-md-6 col-lg-3 text-center wow fadeIn" data-wow-delay="0.7s">
                            <i class="fa fa-car fa-2x text-white mb-3"></i>
                            <h2 class="text-white mb-2" data-toggle="counter-up">2000</h2>
                            <p class="text-white mb-0">Tamamlanan Proje</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container-xxl service py-5">
            <div class="container">
                <div class="text-center">
                    <h6 id="Hizmet" class="text-primary text-uppercase">// Hizmetlerimiz //</h6>
                    <h1 class="mb-5">Hizmetlerimizi Keşfedin</h1>
                </div>

                <div class="row g-4">
                    @{
                        int hCount = 0;
                        var tumHizmetler = Model.Hizmetler.ToList();
                    }
                    <div class="col-lg-4">
                        <div class="nav w-100 nav-pills me-4">
                            @foreach (var item in tumHizmetler)
                            {
                                hCount++;

                                if (hCount == 4)
                                {
                                    @:<div class="collapse w-100" id="extraHizmetNav">
                                    }

                                    <button class="nav-link w-100 d-flex align-items-center text-start p-4 mb-4 @(hCount == 1 ? "active" : "")"
                                            data-bs-toggle="pill" data-bs-target="#tab-pane-@item.HizmetID" type="button">
                                        <i class="fa @item.IkonClass fa-2x me-3"></i>
                                        <h4 class="m-0">@item.Baslik</h4>
                                    </button>
                                }

                            @if (hCount >= 4)
                            {
                            @:</div>
                        }
                        </div>

                        @if (tumHizmetler.Count > 3)
                        {
                            <button class="btn btn-primary w-100 py-3 mt-2" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#extraHizmetNav"
                                    id="btnHizmetGoster" onclick="hizmetYazisiDegistir()">
                                TÜMÜNÜ GÖR +
                            </button>
                        }
                    </div>
                    <div class="col-lg-8">
                        <div class="tab-content w-100">
                            @{ int jCount = 0; }
                            @foreach (var item in tumHizmetler)
                            {
                                jCount++;
                                <div class="tab-pane fade @(jCount == 1 ? "show active" : "")" id="tab-pane-@item.HizmetID">
                                    <div class="row g-4">
                                        <div class="col-md-6" style="min-height: 350px;">
                                            <div class="position-relative h-100">
                                                <img class="position-absolute img-fluid w-100 h-100"
                                                     src="@Url.Content(string.IsNullOrEmpty(item.ResimYolu) ? "~/tema/img/service-1.jpg" : item.ResimYolu)"
                                                     style="object-fit: cover; border-radius: 10px;" alt="@item.Baslik">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <h3 class="mb-3">@item.Baslik</h3>
                                            <p class="mb-4">@Html.Raw(item.Aciklama)</p>
                                            <p><i class="fa fa-check text-success me-3"></i>Kaliteli Hizmet</p>
                                            <p><i class="fa fa-check text-success me-3"></i>Uzman Çalışanlar</p>
                                            <p><i class="fa fa-check text-success me-3"></i>Modern Ekipmanlar</p>
                                            <a href="#Teklif-formu" class="btn btn-danger py-3 px-5 mt-3">RANDEVU AL <i class="fa fa-arrow-right ms-3"></i></a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>


        <div id="Teklif-formu" class="container-fluid bg-secondary booking my-5 wow fadeInUp" data-wow-delay="0.1s">
            <div class="container">
                <div class="row gx-5">
                    <div class="col-lg-6 py-5">
                        <div class="py-5">
                            <h1 class="text-white mb-4">Sertifikalı ve Ödüllü Araç Tamir Servis Sağlayıcısı</h1>
                            <p class="text-white mb-0">Hemen randevunuzu alın, aracınızın bakımını profesyonellere bırakın. Güvenilir ve hızlı hizmetin adresi.</p>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="bg-primary h-100 d-flex flex-column justify-content-center text-center p-5 wow zoomIn" data-wow-delay="0.6s">
                            <h1 class="text-white mb-4">Hemen Randevu Al</h1>
                            <form method="post" action="/Default/RandevuAl">
                                <div class="row g-3">
                                    <div class="col-12 col-sm-6">
                                        <input type="text" name="MusteriAdSoyad" value="@(Session["UyeAd"] ?? "")" class="form-control border-0" placeholder="Adınız Soyadınız" style="height: 55px;" required @(Session["UyeID"] != null ? "readonly" : "")>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <input type="email" name="MusteriEmail" value="@(Session["UyeEmail"] ?? "")" class="form-control border-0" placeholder="E-posta Adresiniz" style="height: 55px;" required @(Session["UyeID"] != null ? "readonly" : "")>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <select name="HizmetTuru" class="form-select border-0" style="height: 55px;">
                                            <option selected>Hizmet Seçin</option>
                                            <option value="Diyagnostik Test">Diyagnostik Test</option>
                                            <option value="Motor Bakımı">Motor Bakımı</option>
                                            <option value="Yağ Değişimi">Yağ Değişimi</option>
                                            <option value="Yağ Değişimi">Oto Yıkama</option>
                                            <option value="Yağ Değişimi">Yol Yardım</option>
                                            <option value="Yağ Değişimi">Alt Bakım</option>
                                        </select>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <input type="date" name="RandevuTarihi" class="form-control border-0" style="height: 55px;" required>
                                    </div>
                                    <div class="col-12">
                                        <textarea name="OzelTalep" class="form-control border-0" id="summernote" placeholder="Özel Talepleriniz"></textarea>
                                    </div>
                                    <div class="col-12">
                                        <button class="btn btn-secondary w-100 py-3" type="submit">Şimdi Randevu Al</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container-fluid page-header mb-5 p-0" style="background-image: url(../tema/img/gama.jpg); background-size: cover;">
            <div class="container-fluid page-header-inner py-5">
                <div class="container text-center">
                    <h1 id="Iletisim" class="display-3 text-white mb-3 animated slideInDown">İletişim</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb justify-content-center text-uppercase">
                            <li class="breadcrumb-item"><a href="/Default/Index">AnaSayfa</a></li>
                            <li class="breadcrumb-item text-white active" aria-current="page">İletişim</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>

        <div class="container-xxl py-5">
            <div class="container">
                <div class="row g-4">
                    <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                        <div class="h-100 shadow-sm rounded-4 overflow-hidden border" style="min-height: 400px;">
                            <iframe class="w-100 h-100"
                                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1521.1017700410046!2d36.55625559376665!3d40.31564006263756!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x407db713f786a31b%3A0xfb59694557efec0f!2sDabakhane%20Cami!5e0!3m2!1str!2sus!4v1772796099620!5m2!1str!2sus"
                                    frameborder="0" style="border:0;" allowfullscreen="" aria-hidden="false"
                                    tabindex="0"></iframe>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="wow fadeInUp shadow-lg p-4 p-md-5 rounded-4 bg-white h-100 border" data-wow-delay="0.2s">

                            @if (Session["UyeID"] != null)
                            {
                                <div class="text-center mb-4">
                                    <h6 class="text-primary text-uppercase font-weight-bold">// Bize Yazın //</h6>
                                    <h2 class="mb-2">Mesaj Gönder</h2>
                                    <p class="text-muted small">Sayın <b>@Session["UyeAd"]</b>, sorularınızı buradan iletebilirsiniz.</p>
                                </div>

                                <form action="/Default/MesajGonder" method="post">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-floating border-bottom">
                                                <input type="text" class="form-control border-0 bg-light" value="@Session["UyeAd"]" name="AdSoyad" id="name" readonly>
                                                <label for="name">Adınız</label>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-floating border-bottom">
                                                <input type="email" class="form-control border-0 bg-light" value="@Session["UyeEmail"]" name="Email" id="email" readonly>
                                                <label for="email">E-postanız</label>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="form-floating border-bottom">
                                                <input type="text" class="form-control border-0" name="Konu" id="subject" placeholder="Konu" required>
                                                <label for="subject">Konu</label>
                                            </div>
                                        </div>
                                        <label for="message">Mesajınız</label>
                                        <div class="col-12">
                                            <div class="form-floating border-bottom">
                                                <textarea class="form-control border-0" name="Mesaj" placeholder="Mesajınız" id="summernote_mesaj" style="height: 100px" required></textarea>
                                            </div>
                                        </div>
                                        <div class="col-12 mt-4">
                                            <button class="btn btn-primary w-100 py-3 rounded-pill shadow-sm" type="submit">
                                                <i class="fa fa-paper-plane me-2"></i>Mesajı İlet
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            }
                            else
                            {
                                <div class="text-center py-4 d-flex flex-column justify-content-center h-100">
                                    <div class="mb-4">
                                        <i class="fa fa-lock fa-4x text-primary opacity-25"></i>
                                    </div>
                                    <h4 class="fw-bold">Mesaj Gönderimi Kısıtlı</h4>
                                    <p class="text-muted px-3">Sorularınızı bize iletmek için lütfen üye girişi yapın.</p>
                                    <div class="mt-3">
                                        <a href="/Default/KayitOl" class="btn btn-primary py-3 px-5 rounded-pill shadow">
                                            <i class="fa fa-user-plus me-2"></i>Giriş Yap / Üye Ol
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Point start -->
        <div class="container-fluid page-header mb-5 p-0" style="background-image: url(../tema/img/gama.jpg);">
            <div class="container-fluid page-header-inner py-5">
                <div class="container text-center">
                    <h1 class="display-3 text-white mb-3 animated slideInDown">Yorumlar</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb justify-content-center text-uppercase">
                            <li class="breadcrumb-item"><a href="#">AnaSayfa</a></li>
                            <li class="breadcrumb-item"><a href="#">Sayfalar</a></li>
                            <li class="breadcrumb-item text-white active" aria-current="page">Yorumlar</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>

        <div class="container-xxl py-5">
            <div class="container text-center">
                <div class="row justify-content-center">
                    <div class="col-lg-4 col-md-6">
                        <div class="bg-light rounded p-4 shadow-sm border-bottom border-5 border-primary wow fadeInUp" data-wow-delay="0.1s">
                            <h1 class="display-1 text-primary mb-0">@orty.ToString("0.0")</h1>

                            <div class="mb-2 d-flex justify-content-center">
                                @for (int y = 1; y <= 5; y++)
                                {
                                    double d_ort = Convert.ToDouble(orty);

                                    if (y <= d_ort)
                                    {
                                        <img src="/tema/img/icons8-star-full30.png" style="width:25px; height:25px; margin:2px;" />
                                    }
                                    else if (y - 0.5 <= d_ort)
                                    {
                                        <img src="/tema/img/icons8-star-half-30.png" style="width:25px; height:25px; margin:2px;" />
                                    }
                                    else
                                    {
                                        <img src="/tema/img/icons8-star-empty30.png" style="width:25px; height:25px; margin:2px;" />
                                    }
                                }
                            </div>

                            <p class="mb-0 fw-bold">Genel Müşteri Memnuniyeti</p>
                            <small class="text-muted">(@onayliYorumlar.Count() Müşteri Değerlendirmesi)</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Point start -->
        <!-- Comment start -->
        <div id="Yorumlar" class="container-xxl py-5" style="background: #fdfdfd; min-height: 500px;">
            <div class="container">
                <div class="text-center mb-5">
                    <h6 class="text-primary text-uppercase fw-bold">// YORUMLAR //</h6>
                    <h1 class="mb-5">Müşterilerimiz Ne Diyor!</h1>
                </div>

                <div class="row g-4 justify-content-center">
                    @{ int yorumSayac = 0; }

                    @foreach (var item in Model.Yorumlar.Where(x => x.Durum == true).OrderByDescending(x => x.YorumID))
                    {
                        yorumSayac++;
                        if (yorumSayac == 4)
                        {
                            @:<div class="row g-4 justify-content-center collapse" id="extraYorumlar">
                            }

                            <div class="col-lg-4 col-md-6">
                                <div class="testimonial-item bg-white rounded shadow-sm p-4 text-center border h-100">
                                    <img class="bg-light rounded-circle p-2 mx-auto mb-3"
                                         src="@(item.Tbl_Uyeler != null && !string.IsNullOrEmpty(item.Tbl_Uyeler.UyeResim) ? item.Tbl_Uyeler.UyeResim : "/tema/img/uyeler/user-profile.png")"
                                         style="width: 80px; height: 80px; object-fit: cover; border: 2px solid #FEA116;">

                                    <div class="mb-3" style="line-height: 0;">
                                        @for (int y = 1; y <= 5; y++)
                                        {
                                            double p = Convert.ToDouble(item.Puan ?? 0);
                                            if (y <= p)
                                            {<img src="/tema/img/icons8-star-full30.png" style="width:18px; height:18px; display:inline-block;" /> }
                                            else if (y - 0.5 <= p)
                                            { <img src="/tema/img/icons8-star-half-30.png" style="width:18px; height:18px; display:inline-block;" /> }
                                            else
                                            { <img src="/tema/img/icons8-star-empty30.png" style="width:18px; height:18px; display:inline-block;" />}
                                        }
                                    </div>

                                    <h5 class="mb-1">@item.MusteriAdSoyad</h5>
                                    <p class="text-muted small mb-3">
                                        <i class="far fa-calendar-alt text-primary me-1"></i>
                                        @item.YorumTarihi.Value.ToString("dd MMMM yyyy")
                                    </p>

                                    <div class="testimonial-text bg-light rounded p-4">
                                        <i class="fa fa-quote-left text-primary mb-2 opacity-50"></i>
                                        <p class="mb-0 italic">@Html.Raw(item.YorumMetni)</p>
                                    </div>
                                </div>
                            </div>
                        }

                    @if (yorumSayac >= 4)
                    {
                    @:</div>
                }
                </div>
                @if (yorumSayac > 3)
                {
                    <div class="text-center mt-5">
                        <button class="btn btn-primary py-3 px-5 rounded-pill shadow" type="button"
                                data-bs-toggle="collapse" data-bs-target="#extraYorumlar"
                                id="btnToggleYorum" onclick="yorumBtnDegistir()">
                            Tüm Müşteri Yorumlarını Gör
                        </button>
                    </div>
                }
            </div>
        </div>

        <div class="row justify-content-center mt-5">
            <div class="col-lg-8">
                <div class="bg-white rounded shadow-lg p-4 p-md-5 border-top border-5 border-primary">
                    <div class="text-center mb-4">
                        <h4 class="fw-bold">Deneyimini Bizimle Paylaş</h4>
                        <p class="text-muted">Görüşleriniz hizmet kalitemizi artırmamıza yardımcı olur.</p>
                    </div>

                    <form action="/Default/YorumEkle" method="post">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" value="@(Session["UyeAd"] ?? "")" name="MusteriAdSoyad" class="form-control" id="name" placeholder="Ad Soyad" required @(Session["UyeID"] != null ? "readonly" : "")>
                                    <label for="name">Adınız Soyadınız</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" name="Meslek" class="form-control" id="job" placeholder="Meslek">
                                    <label for="job">Mesleğiniz (Opsiyonel)</label>
                                </div>
                            </div>

                            <div class="col-12 text-center bg-light py-3 rounded border">
                                <span class="d-block mb-2 fw-bold text-dark">Deneyim Puanınız: </span>
                                <div id="star-rating-input">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <input type="radio" name="Puan" id="puan-@s" value="@s" style="display:none;" @(s == 5 ? "required" : "")>
                                        <label for="puan-@s" style="cursor:pointer;" onclick="yildizSec(@s)">
                                            <img src="/tema/img/icons8-star-empty30.png" id="yildiz-resim-@s" width="30" height="30" />
                                        </label>
                                    }
                                </div>
                            </div>

                            <div class="col-12">
                                <textarea name="YorumMetni" class="form-control" id="summernote_yorum" placeholder="Deneyiminizi detaylandırın..." required></textarea>
                            </div>

                            <div class="col-12">
                                <div class="bg-light p-3 rounded d-flex align-items-center justify-content-between border">
                                    <label class="mb-0 text-danger fw-bold">Güvenlik Kontrolü: <span class="badge bg-white text-dark ms-2 border px-3 py-2">@ViewBag.GosterilenKod</span></label>
                                    <input type="text" name="KullaniciKodu" class="form-control ms-3" style="max-width: 250px;" placeholder="Kodu buraya yazınız" required>
                                </div>
                            </div>

                            <div class="col-12">
                                <button class="btn btn-primary w-100 py-3 rounded-pill shadow" type="submit">
                                    <i class="fa fa-paper-plane me-2"></i>Değerlendirmeyi Gönder
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <!-- Comment end -->

        <div class="container-fluid page-header mb-5 p-0" style="background-image: url(../tema/img/gama.jpg);">
            <div class="container-fluid page-header-inner py-5">
                <div class="container text-center">
                    <h1 class="display-3 text-white mb-3 animated slideInDown">Sıkça Sorulan Sorular</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb justify-content-center text-uppercase">
                            <li class="breadcrumb-item"><a href="#">AnaSayfa</a></li>
                            <li class="breadcrumb-item"><a href="#">Sayfalar</a></li>
                            <li class="breadcrumb-item text-white active" aria-current="page">Sıkça Sorulan Sorular</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>

        <div class="container-xxl py-5 wow fadeInUp" data-wow-delay="0.1s">
            <div class="container">
                <div class="text-center mx-auto mb-5">
                    <h6 class="text-primary text-uppercase">// SSS //</h6>
                    <h1 class="mb-5">Sıkça Sorulan Sorular</h1>
                </div>
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="accordion" id="accordionSSS">
                            @{ int sayac = 0; }

                            @foreach (var item in Model.SSS.Where(x => x.Durum == true).OrderBy(x => x.Sira))
                            {
                                sayac++;
                                if (sayac == 3)
                                {
                                    @:<div class="collapse" id="extraSSS">
                                    }

                                    <div class="accordion-item border-0 mb-3 shadow-sm">
                                        <h2 class="accordion-header" id="heading-@item.ID">
                                            <button class="accordion-button @(sayac == 1 ? "" : "collapsed")" type="button"
                                                    data-bs-toggle="collapse" data-bs-target="#soru-@item.ID">
                                                <b class="text-dark me-2">@sayac.</b> @item.Soru
                                            </button>
                                        </h2>
                                        <div id="soru-@item.ID" class="accordion-collapse collapse @(sayac == 1 ? "show" : "")"
                                             data-bs-parent="#accordionSSS">
                                            <div class="accordion-body bg-light">
                                                @item.Cevap
                                            </div>
                                        </div>
                                    </div>
                                }
                            @if (sayac >= 3)
                            {
                            @:</div>
                        }
                        </div>
                        @if (sayac > 2)
                        {
                            <div class="text-center mt-5">
                                <button class="btn btn-primary py-3 px-5" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#extraSSS"
                                        id="btnToggleSSS" onclick="btnDegistir()">
                                    Tüm Soruları Gör
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>