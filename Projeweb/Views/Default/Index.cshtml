@model Projeweb.Controllers.AnasayfaViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}
<!DOCTYPE html>
<html lang="tr">
@{
    var db = new Projeweb.Models.GAMAOTOWEBEntities();
    var onayliYorumlar = db.Tbl_Yorumlar.Where(x => x.Durum == true);

    decimal orty = 0;
    if (onayliYorumlar.Any())
    {
        orty = (decimal)onayliYorumlar.Average(x => x.Puan);
    }
}
<body>
    
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Yükleniyor...</span>
        </div>
    </div>
    <div class="container-fluid p-0 mb-5">
        <div id="header-carousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                @{ int i = 0; }
                @foreach (var item in Model.Resimler)
                {
                    i++;
                    <div class="carousel-item @(i == 1 ? "active" : "")">
                        <img class="w-100" src="@item.ArkaPlanResim" alt="Resim">
                        <div class="carousel-caption d-flex align-items-center">
                            <div class="container">
                                <div class="row align-items-center justify-content-center justify-content-lg-start">
                                    <div class="col-10 col-lg-7 text-center text-lg-start">
                                        <h6 class="text-white text-uppercase mb-3 animated slideInDown">@item.UstBaslik</h6>
                                        <h1 class="display-3 text-white mb-4 pb-3 animated slideInDown">@item.Baslik</h1>
                                    </div>
                                    <div class="col-lg-5 d-none d-lg-flex animated zoomIn">
                                        <img class="img-fluid" src="@item.OnResim" alt="">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#header-carousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Geri</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#header-carousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">İleri</span>
            </button>
        </div>
    </div>

    <div class="container-xxl py-5">
        <div class="container">
            <div class="text-center mb-5 wow fadeInUp" data-wow-delay="0.1s">
                <h6 class="text-primary text-uppercase">// DUYURULAR //</h6>
                <h1 class="mb-0">Güncel Haberler ve Duyurular</h1>
            </div>
            <div class="row g-4">
                @{
                    var tumDuyurular = Model.Duyurular.Where(x => x.Durum == true).OrderByDescending(x => x.Tarih).ToList();
                    int toplamDuyuru = tumDuyurular.Count();
                    var ilkUclu = tumDuyurular.Take(3).ToList();
                    var kalanlar = tumDuyurular.Skip(3).ToList();
                }

                @foreach (var item in ilkUclu)
                {
                    <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                        <div class="bg-light rounded overflow-hidden shadow-sm h-100">
                            <img class="img-fluid w-100" src="@item.ResimYolu" style="height:200px; object-fit:cover;">
                            <div class="p-4">
                                <div class="d-flex justify-content-start mb-3 small">
                                    <span class="text-muted me-3"><i class="fa fa-calendar-alt text-primary me-2"></i>@item.Tarih.Value.ToString("dd.MM.yyyy")</span>
                                    <span class="text-muted me-3"><i class="fa fa-heart text-danger me-2"></i>@item.BegeniSayisi</span>
                                    <span class="text-muted"><i class="fa fa-eye text-primary me-2"></i>@item.Goruntulenme</span>
                                </div>
                                <h5 class="mb-3">@item.Baslik</h5>
                                <p>@Html.Raw(item.DuyuruMetni.Length > 100 ? item.DuyuruMetni.Substring(0, 100) + "..." : item.DuyuruMetni)</p>
                                <a class="btn btn-outline-primary rounded-pill py-2 px-4 mt-3" href="/Default/DuyuruDetay/@item.DuyuruID">Devamını Oku...</a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (toplamDuyuru > 3)
            {
                <div class="collapse" id="extraDuyurular">
                    <div class="row g-4 mt-2">
                        @foreach (var item in kalanlar)
                        {
                            <div class="col-lg-4 col-md-6">
                                <div class="bg-light rounded overflow-hidden shadow-sm h-100">
                                    <img class="img-fluid w-100" src="@item.ResimYolu" style="height:200px; object-fit:cover;">
                                    <div class="p-4">
                                        <div class="d-flex justify-content-start mb-3 small">
                                            <span class="text-muted me-3"><i class="fa fa-calendar-alt text-primary me-2"></i>@item.Tarih.Value.ToString("dd.MM.yyyy")</span>
                                            <span class="text-muted me-3"><i class="fa fa-heart text-danger me-2"></i>@item.BegeniSayisi</span>
                                            <span class="text-muted"><i class="fa fa-eye text-primary me-2"></i>@item.Goruntulenme</span>
                                        </div>
                                        <h5 class="mb-3">@item.Baslik</h5>
                                        <p>@Html.Raw(item.DuyuruMetni.Length > 100 ? item.DuyuruMetni.Substring(0, 100) + "..." : item.DuyuruMetni)</p>
                                        <a class="btn btn-outline-primary rounded-pill py-2 px-4 mt-3" href="/Default/DuyuruDetay/@item.DuyuruID">Devamını Oku...</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="text-center mt-5">
                    <button class="btn btn-primary py-3 px-5 rounded-pill shadow" type="button"
                            data-bs-toggle="collapse" data-bs-target="#extraDuyurular"
                            id="btnDuyuruToggle" onclick="duyuruBtnDegistir()">
                        Tüm Duyuruları Gör <i class="fa fa-plus ms-2"></i>
                    </button>
                </div>
            }
        </div>
    </div>


    @*<div class="container-xxl py-5">
            <div class="container">
                <div class="row g-4">
                    <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="d-flex py-5 px-4">
                            <i class="fa fa-certificate fa-3x text-primary flex-shrink-0"></i>
                            <div class="ps-4">
