@model List<Projeweb.Models.Tbl_Yorumlar>
@{
    ViewBag.Title = "Yorumlarım";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
        <h6 class="text-primary text-uppercase">// Profilim //</h6>
        <h1 class="mb-5">Yaptığınız Yorumlar</h1>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 wow fadeInUp" data-wow-delay="0.3s">
                <div class="testimonial-item bg-light rounded p-4 shadow-sm border-top border-5 border-primary h-100">
                    <div class="d-flex align-items-center mb-3">
                        <i class="fa fa-quote-left fa-2x text-primary me-3"></i>
                        <div>
                            <small class="text-muted">@item.YorumTarihi.Value.ToString("dd.MM.yyyy")</small>
                            <h6 class="mb-0">
                                @if (item.Durum == true)
                                {<span class="text-success small">● Yayında</span> }
                                else
                                { <span class="text-warning small">● Onay Bekliyor</span>}
                            </h6>
                        </div>
                    </div>
                    <p class="mb-0">@item.YorumMetni</p>
                    <hr />
                    <a href="/Default/YorumSil/@item.YorumID" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silinsin mi?')">
                        <i class="fa fa-trash me-1"></i> Sil
                    </a>
                </div>
            </div>
        }

        @if (ViewBag.DuyuruYorumlari != null)
        {
            foreach (var item in (List<Projeweb.Models.Tbl_DuyuruYorumlar>)ViewBag.DuyuruYorumlari)
            {
                <div class="col-md-6 col-lg-4 wow fadeInUp" data-wow-delay="0.3s">
                    <div class="testimonial-item bg-white rounded p-4 shadow-sm border-top border-5 border-info h-100">
                        <div class="d-flex align-items-center mb-3">
                            <i class="fa fa-bullhorn fa-2x text-info me-3"></i>
                            <div>
                                <small class="text-muted">@item.Tarih.Value.ToString("dd.MM.yyyy") <br /> (Duyuru Yorumu)</small>
                                <h6 class="mb-0">
                                    @if (item.Durum == true)
                                    {<span class="text-success small">● Yayında</span> }
                                    else
                                    { <span class="text-warning small">● Onay Bekliyor</span>}
                                </h6>
                            </div>
                        </div>
                        <p class="mb-0">@item.YorumMetni</p>
                        <hr />
                        <a href="/Default/DuyuruYorumSil/@item.YorumID" class="btn btn-sm btn-outline-danger" onclick="return confirm('Duyuru yorumunu silmek istediğinize emin misiniz?')">
                            <i class="fa fa-trash me-1"></i> Sil
                        </a>
                    </div>
                </div>
            }
        }
    </div>

    @if (!Model.Any() && (ViewBag.DuyuruYorumlari == null || ((List<Projeweb.Models.Tbl_DuyuruYorumlar>)ViewBag.DuyuruYorumlari).Count == 0))
    {
        <div class="text-center py-5">
            <p class="text-muted">Henüz hiç yorum yapmamışsınız.</p>
        </div>
    }
</div>