@using Projeweb.Models
<div class="container-fluid bg-dark text-light footer pt-5 mt-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container py-5">
        <div class="row g-5">
            <div class="col-lg-3 col-md-6">
                <h4 class="text-light mb-4">Adres</h4>
                <p class="mb-2"><i class="fa fa-map-marker-alt me-3"></i>@Model.Adres</p>
                <p class="mb-2"><i class="fa fa-phone-alt me-3"></i>@Model.Telefon</p>
                <p class="mb-2"><i class="fa fa-envelope me-3"></i>@Model.Email</p>
                <div class="d-flex pt-2">
                    <a class="btn btn-outline-light btn-social" href="@Model.Twitter"><i class="fab fa-twitter"></i></a>
                    <a class="btn btn-outline-light btn-social" href="@Model.Facebook"><i class="fab fa-facebook-f"></i></a>
                    <a class="btn btn-outline-light btn-social" href="@Model.Instagram"><i class="fab fa-facebook-f"></i></a>
                    <a class="btn btn-outline-light btn-social" href="@Model.Linkedin"><i class="fab fa-linkedin-in"></i></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <h4 class="text-light mb-4">Çalışma Saatleri</h4>
                <h6 class="text-light">Pazartesi - Cuma:</h6>
                <p class="mb-4">@Model.CalismaSaatleriIci</p>
                <h6 class="text-light">Cumartesi - Pazar:</h6>
                <p class="mb-0">@Model.CalismaSaatleriSonu</p>
            </div>
            <div class="col-lg-3 col-md-6">
                <h4 class="text-light mb-4">Hizmetlerimiz</h4>
                <a class="btn btn-link" href="/Default/TumHizmetler">Arıza Tespiti</a>
                <a class="btn btn-link" href="/Default/TumHizmetler">Motor Servisi</a>
                <a class="btn btn-link" href="/Default/TumHizmetler">Lastik Değişimi</a>
                <a class="btn btn-link" href="/Default/TumHizmetler">Yağ Değişimi</a>
                <a class="btn btn-link" href="/Default/TumHizmetler">Vakum Temizliği</a>
            </div>
            <div class="col-lg-3 col-md-6">
                <h4 class="text-light mb-4">Haberler</h4>
                <p>Kampanyalardan haberdar olmak için kayıt olun.</p>
                <div class="position-relative mx-auto" style="max-width: 400px;">
                    <a href="/Default/KayitOl" class="btn btn-outline-info">Kayıt Ol</a>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="copyright">
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    &copy; <a class="border-bottom" href="~/Admin/GirisYap">GamaOto Servis</a>, Tüm Hakları Saklıdır.
                </div>
            </div>
        </div>
    </div>
</div>
<a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>
