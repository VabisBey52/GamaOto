@using Projeweb.Models

<div class="container-fluid bg-light p-0">
    <div class="row gx-0 d-none d-lg-flex">
        <div class="col-lg-7 px-5 text-start">
            <div class="h-100 d-inline-flex align-items-center py-3 me-4">
                <small class="fa fa-map-marker-alt text-primary me-2"></small>
                <small>@Model.Adres</small>
            </div>
            <div class="h-100 d-inline-flex align-items-center py-3">
                <small class="far fa-clock text-primary me-2"></small>
                <small>Pzt - Cum : @Model.CalismaSaatleriSonu</small>
            </div>
        </div>
        <div class="col-lg-5 px-5 text-end">
            <div class="h-100 d-inline-flex align-items-center py-3 me-4">
                <small class="fa fa-phone-alt text-primary me-2"></small>
                <small>@Model.Telefon</small>
            </div>
            <div class="h-100 d-inline-flex align-items-center">
                <a class="btn btn-sm-square bg-white text-primary me-1" href="@Model.Facebook"><i class="fab fa-facebook-f"></i></a>
                <a class="btn btn-sm-square bg-white text-primary me-1" href="@Model.Twitter"><i class="fab fa-twitter"></i></a>
                <a class="btn btn-sm-square bg-white text-primary me-1" href="@Model.Instagram"><i class="fab fa-instagram"></i></a>
                <a class="btn btn-sm-square bg-white text-primary me-0" href="@Model.Linkedin"><i class="fab fa-instagram"></i></a>
            </div>
        </div>
    </div>
</div>
<nav class="navbar navbar-expand-lg bg-white navbar-light shadow sticky-top p-0">
    <a href="#" class="navbar-brand d-flex align-items-center px-4 px-lg-5">
        <h2 class="m-0 text-primary"><i class="fa fa-car me-3"></i>GamaOto</h2>
    </a>
    <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarCollapse">
        <div class="navbar-nav ms-auto p-4 p-lg-0">
            <a href="/Default/Index" class="nav-item nav-link active">Anasayfa</a>
            <a href="/Default/TumDuyurular" class="nav-item nav-link">Duyuru & Haberler</a>
            <a href="/Default/TumHizmetler" class="nav-item nav-link">Hizmetler</a>
            <div class="nav-item dropdown">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Sayfalar</a>
                <div class="dropdown-menu fade-up m-0">
                    <a href="/Default/Index#Teklif-formu" class="dropdown-item">Randevu</a>
                    <a href="/Default/IndexTeknisyen" class="dropdown-item">Teknisyenlerimiz</a>
                    <a href="/Default/TumYorumlar" class="dropdown-item">Müşteri Yorumları</a>
                    <a href="/Default/SSS" class="dropdown-item">Sıkça Sorulan Sorular</a>
                    <a href="~/tema/404.html" class="dropdown-item">404 Sayfası</a>
                </div>
            </div>
            <a href="/Default/Index#Iletisim" class="nav-item nav-link">İletişim</a>
        </div>
        @if (Session["UyeID"] != null)
        {
            @* Kullanıcı Giriş Yapmışsa *@
            <div class="nav-item dropdown">
                <a href="#" class="nav-link dropdown-toggle d-flex align-items-center" data-bs-toggle="dropdown">
                    <img src="@Session["UyeResim"]" class="rounded-circle me-2" width="30" height="30" style="object-fit: cover;">
                    <span>@Session["UyeAd"]</span>
                </a>
                <div class="dropdown-menu m-0 shadow-sm border-0">
                    <a href="/Default/Profilim" class="dropdown-item">Profilim</a>
                    <a href="/Default/Randevularim" class="dropdown-item">Randevularım</a>
                    <a href="/Default/Yorumlarim" class="dropdown-item">Yorumlarım</a>
                    <a href="/Default/Mesajlarim" class="dropdown-item">Mesajlarım</a>
                    <a href="/Default/CikisYap" class="dropdown-item text-danger">Güvenli Çıkış</a>
                </div>
            </div>
        }
        else
        {
            <a href="/Default/GirisYap" class="nav-item nav-link">Giriş Yap</a>
            <span class="nav-link disabled px-0">/</span>
            <a href="/Default/KayitOl" class="nav-item nav-link">Üye Ol</a>
        }
    </div>
</nav>
