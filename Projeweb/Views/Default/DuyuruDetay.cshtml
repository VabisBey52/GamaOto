@model Projeweb.Models.Tbl_Duyurular

@{
    ViewBag.Title = Model.Baslik;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8">
            <h1 class="mb-4">@Model.Baslik</h1>
            <div class="position-relative d-inline-block w-100">
                <img src="@Model.ResimYolu"
                     class="img-fluid rounded mb-4 w-100"
                     style="max-height:400px; object-fit:cover; cursor:pointer;"
                     ondblclick="resimBegeni(@Model.DuyuruID, this)">


                <div id="heart-overlay" class="position-absolute top-50 start-50 translate-middle d-none">
                    <i class="fa fa-heart fa-5x text-white opacity-75"></i>
                </div>
            </div>

            <div class="d-flex mb-4 text-muted border-bottom pb-3">
                <span class="me-4"><i class="fa fa-eye text-primary me-2"></i>@Model.Goruntulenme Görüntülenme</span>
                <span style="cursor:pointer;" onclick="begeniYap(@Model.DuyuruID)">
                    <i class="fa fa-heart text-danger me-2"></i>
                    <span id="begeni-sayisi">@Model.BegeniSayisi</span> Beğeni
                </span>
            </div>
            @* Html.Raw summernote de düzgün görunmesi için yapıyoruz *@
            <p style="font-size: 1.1rem; line-height: 1.8;">@Html.Raw(Model.DuyuruMetni)</p>

            <div class="mt-5">
                <h5 class="mb-4">Yorumlar</h5>
                @foreach (var y in (List<Projeweb.Models.Tbl_DuyuruYorumlar>)ViewBag.OnayliYorumlar)
                {
                    <div class="d-flex bg-white p-3 mb-3 rounded shadow-sm border">
                        <div class="flex-shrink-0">
                            @if (y.UyeID != null && !string.IsNullOrEmpty(y.Tbl_Uyeler?.UyeResim))
                            {
                                <img src="@y.Tbl_Uyeler.UyeResim" class="rounded-circle border" style="width: 55px; height: 55px; object-fit: cover;" alt="Profil">
                            }
                            else
                            {
                                <img src="~/tema/img/uyeler/user-profile.png" class="rounded-circle border" style="width: 55px; height: 55px; object-fit: cover;" alt="Ziyaretçi">
                            }
                        </div>

                        <div class="ms-3 w-100">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <h6 class="mb-0 fw-bold text-primary">
                                    @y.AdSoyad
                                    @if (y.UyeID != null)
                                    {<i class="fa fa-check-circle text-info ms-1" title="Onaylı Üye"></i>}
                                </h6>
                                <small class="text-muted" style="font-size: 0.8rem;">
                                    <i class="fa fa-calendar-alt me-1"></i> @y.Tarih.Value.ToString("dd.MM.yyyy HH:mm")
                                </small>
                            </div>
                            <p class="mb-0 text-secondary" style="line-height: 1.5;">@y.YorumMetni</p>
                        </div>
                    </div>
                }

                @if (((List<Projeweb.Models.Tbl_DuyuruYorumlar>)ViewBag.OnayliYorumlar).Count == 0)
                {
                    <div class="alert alert-light border text-center text-muted">Henüz yorum yapılmamış. İlk yorumu sen yap!</div>
                }
            </div>

            <div class="mt-5 bg-light p-4 rounded shadow-sm">
                <h4 class="mb-4">Yorum Yap</h4>
                <form action="/Default/DuyuruYorumEkle" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="DuyuruID" value="@Model.DuyuruID" />

                    @if (Session["UyeID"] == null)
                    {
                        <div class="mb-3">
                            <input type="text" name="AdSoyad" class="form-control" placeholder="Adınız Soyadınız" required />
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="AdSoyad" value="@Session["UyeAd"]" />
                        <p class="small text-muted"><strong>@Session["UyeAd"]</strong> olarak yorum yapıyorsunuz.</p>
                    }

                    <div class="col-12">
                        <div class="bg-light p-3 rounded d-flex align-items-center justify-content-between border">
                            <label class="mb-0 text-danger fw-bold">Güvenlik Kontrolü: <span class="badge bg-white text-dark ms-2 border px-3 py-2">@ViewBag.GosterilenKod</span></label>
                            <input type="text" name="KullaniciKodu" class="form-control ms-3" style="max-width: 250px;" placeholder="Kodu buraya yazınız" required>
                        </div>
                    </div>

                    <textarea class="form-control mb-3" name="YorumMetni" rows="3" placeholder="Mesajınız..." required></textarea>
                    <button type="submit" class="btn btn-primary w-100 py-3">Gönder</button>
                </form>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="bg-light p-4 rounded shadow-sm">
                <h4 class="mb-4 border-bottom pb-2">Diğer Duyurular</h4>

                @if (ViewBag.DigerDuyurular != null)
                {
                    foreach (var item in (List<Projeweb.Models.Tbl_Duyurular>)ViewBag.DigerDuyurular)
                    {
                        <div class="d-flex align-items-center mb-3 pb-3 border-bottom">
                            <img src="@item.ResimYolu" class="rounded" style="width: 80px; height: 60px; object-fit: cover;">
                            <div class="ms-3">
                                <h6 class="mb-1">
                                    <a href="/Default/DuyuruDetay/@item.DuyuruID" class="text-dark text-decoration-none fw-bold">
                                        @(item.Baslik.Length > 40 ? item.Baslik.Substring(0, 40) + "..." : item.Baslik)
                                    </a>
                                </h6>
                                <small class="text-muted"><i class="fa fa-calendar-alt me-1"></i> @item.Tarih.Value.ToString("dd.MM.yyyy")</small>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">Başka duyuru bulunamadı.</p>
                }

                <div class="mt-4">
                    <a href="/Default/TumDuyurular" class="btn btn-outline-primary w-100">Tümünü Gör</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var mesaj = '@TempData["Mesaj"]';
        var durum = '@TempData["Durum"]';

        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "5000"
        };

        if (mesaj) {
            if (durum == "danger") {
                toastr.error(mesaj);
            } else if (durum == "success") {
                toastr.success(mesaj);
            } else if (durum == "warning") {
                toastr.warning(mesaj);
            } else {
                toastr.info(mesaj);
            }
        }
    });

    function begeniYap(id) {
        $.post("/Default/BegeniArtir/" + id, function (data) {
            if (data.success) {
                $("#begeni-sayisi").text(data.newCount);
                toastr.success("Duyuruyu beğendiniz!");
            } else {
                toastr.error("Bir hata oluştu veya zaten beğendiniz.");
            }
        });
    }

    function resimBegeni(id, element) {
        begeniYap(id);

        var heart = document.getElementById("heart-overlay");
        heart.classList.remove("d-none");

        setTimeout(function () {
            heart.classList.add("d-none");
        }, 800);
    }
</script>

<style>
    /* Kalbin daha yumuşak görünmesi için basit bir animasyon */
    #heart-overlay i {
        animation: heartPop 0.8s ease-out;
        text-shadow: 0 0 20px rgba(0,0,0,0.5);
    }

    @@keyframes heartPop {
        0% { transform: scale(0); opacity: 0; }
        50% { transform: scale(1.3); opacity: 1; }
        100% { transform: scale(1); opacity: 0; }
    }
</style>