
<!doctype html>
<html lang="tr">
<head>
    <title>Gama OTO | Yönetim Paneli</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800,900" rel="stylesheet">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/temaAdmin/css/style.css">

    <script src="https://code.jquery.com/jquery-3.5.1.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js" integrity="sha384-Q6E9RHvbIyZFJoft+2mJbHaEWldlvI9IOYy5n3zV9zzTtmI3UksdQRVvoxMfooAo" crossorigin="anonymous"></script>

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css" integrity="sha384-Vkoo8x4CGsO3+Hhxv8T/Q5PaXtkKtu6ug5TOeNV6gBiFeWPGFN9MuhOf23Q9Ifjh" crossorigin="anonymous">
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js" integrity="sha384-wfSDF2E50Y2D1uUdj0O3uMBJnjuUD4Ih7YwaYd1iqfktj0Uod8GCExl3Og8ifwB6" crossorigin="anonymous"></script>

    <link href="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/summernote-bs4.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/summernote-bs4.min.js"></script>

    <style>
        #sidebar .logo-text {
            color: #fff;
            text-align: center;
            display: block;
            font-weight: 700;
            font-size: 20px;
            margin-top: -30px;
            margin-bottom: 30px;
        }
    </style>
</head>
<body>

    <div class="wrapper d-flex align-items-stretch">
        <nav id="sidebar">
            <div class="p-4 pt-5">
                <a href="/Default/IndexAdmin" class="img logo rounded-circle mb-5" style="background-image: url(../temaAdmin/images/sj.jpeg);"></a>
                <span class="logo-text">Gama Oto Admin</span>

                @{
                    // O anki sayfanın (Action) adını alıyoruz
                    string aktifSayfa = ViewContext.RouteData.Values["action"].ToString();
                }

                <ul class="list-unstyled components mb-5">
                    <li class="@(aktifSayfa == "Resimlerekle" ? "active" : "")">
                        <a href="/Default/Resimlerekle"><i class="fa fa-dashboard mr-3"></i> Resimler</a>
                    </li>

                    <li class="@(aktifSayfa == "IndexRandevu" ? "active" : "")">
                        <a href="/Default/IndexRandevu"><i class="fa fa-calendar mr-3"></i> Randevular</a>
                    </li>

                    <li class="@(aktifSayfa == "DuyuruListesi" ? "active" : "")">
                        <a href="/Default/DuyuruListesi"><i class="fa fa-calendar mr-3"></i> Duyurular</a>
                    </li>

                    <li class="@(aktifSayfa == "SiteAyarlari" ? "active" : "")">
                        <a href="/Default/SiteAyarlari"><i class="fa fa-bars mr-3"></i> Ayarlar</a>
                    </li>

                    <li class="@(aktifSayfa == "SSSEkle" ? "active" : "")">
                        <a href="/Default/SSSEkle"><i class="fa fa-envelope mr-3"></i> SSS</a>
                    </li>

                    <li class="@(aktifSayfa == "IndexHizmetler" ? "active" : "")">
                        <a href="/Default/IndexHizmetler"><i class="fa fa-bars mr-3"></i> Hizmetler</a>
                    </li>

                    <li class="@(aktifSayfa == "AdminYorumlar" ? "active" : "")">
                        <a href="/Default/AdminYorumlar"><i class="fa fa-comment mr-3"></i> Müşteri Yorumları</a>
                    </li>

                    <li class="@(aktifSayfa == "TeknisyenEkle" ? "active" : "")">
                        <a href="/Default/TeknisyenEkle"><i class="fa fa-users mr-3"></i> Teknisyenler</a>
                    </li>

                    <li class="@(aktifSayfa == "GelenMesajlar" || aktifSayfa == "MesajDetay" ? "active" : "")">
                        <a href="/Default/GelenMesajlar"><i class="fa fa-envelope mr-3"></i> İletişim Mesajları</a>
                    </li>
                </ul>

                <div class="footer">
                    <p>
                        Copyright &copy;
                        <script>document.write(new Date().getFullYear());</script>
                        Tüm Hakları Saklıdır | Gama Oto
                    </p>
                </div>
            </div>
        </nav>

        <div id="content" class="p-4 p-md-5">

            <nav class="navbar navbar-expand-lg navbar-light bg-light">
                <div class="container-fluid">

                    <button type="button" id="sidebarCollapse" class="btn btn-primary">
                        <i class="fa fa-bars"></i>
                        <span class="sr-only">Menüyü Kapat</span>
                    </button>

                    <div class="ml-auto">
                        <span class="text-muted mr-3">Hoş geldin, <strong>Admin</strong></span>
                        <a href="/Admin/CikisYap" class="btn btn-outline-danger btn-sm">Çıkış Yap</a>
                    </div>
                </div>
            </nav>

            @RenderBody()

        </div>
    </div>

    <script src="~/temaAdmin/js/jquery.min.js"></script>
    <script src="~/temaAdmin/js/popper.js"></script>
    <script src="~/temaAdmin/js/bootstrap.min.js"></script>
    <script src="~/temaAdmin/js/main.js"></script>
</body>
</html>